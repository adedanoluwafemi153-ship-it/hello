def get_grade_point(grade):
    """Returns the matching grade point utilizing conditional selection statements."""
    grade = grade.upper().strip()
    if grade == 'A':
        return 5
    elif grade == 'B':
        return 4
    elif grade == 'C':
        return 3
    elif grade == 'D':
        return 2
    elif grade == 'E':
        return 1
    elif grade == 'F':
        return 0
    else:
        return None

def calculate_semester_gpa():
    print("\n--- Semester Data Input ---")
    try:
        num_courses = int(input("Enter the number of courses offered this semester: "))
    except ValueError:
        print("Invalid number. Returning to main menu.")
        return 0, 0

    total_quality_points = 0
    total_credit_units = 0

    for i in range(1, num_courses + 1):
        print(f"\nCourse {i}:")
        try:
            units = int(input("  Enter Credit Units (e.g., 2, 3, 4): "))
        except ValueError:
            print("  Invalid input. Skipping this course.")
            continue

        grade = input("  Enter Letter Grade earned (A, B, C, D, E, F): ")
        gp = get_grade_point(grade)

        if gp is None:
            print("  Invalid Grade entered! Skipping this course.")
            continue

        total_quality_points += (gp * units)
        total_credit_units += units

    if total_credit_units == 0:
        return 0, 0
    
    gpa = total_quality_points / total_credit_units
    return total_quality_points, total_credit_units

def main():
    print("=" * 50)
    print("      PERSONAL POCKET CGPA CALCULATOR (PPC)      ")
    print("=" * 50)
    
    try:
        total_semesters = int(input("How many semesters of results do you want to compute? "))
    except ValueError:
        print("Invalid input. Exiting program.")
        return

    cumulative_points = 0
    cumulative_units = 0

    for sem in range(1, total_semesters + 1):
        print(f"\n================ SEMESTER {sem} ================")
        qp, units = calculate_semester_gpa()
        
        cumulative_points += qp
        cumulative_units += units
        
        if units > 0:
            sem_gpa = qp / units
            print(f"\n>>> Semester {sem} GPA: {sem_gpa:.2f}")
        else:
            print(f"\n>>> No valid data recorded for Semester {sem}.")

    print("\n" + "=" * 50)
    print("                 FINAL SUMMARY                  ")
    print("=" * 50)
    if cumulative_units > 0:
        cgpa = cumulative_points / cumulative_units
        print(f"Total Credit Units Registered: {cumulative_units}")
        print(f"Total Quality Points Earned : {cumulative_points}")
        print(f"Your Cumulative CGPA        : {cgpa:.2f}")
        
        # Degree Class Selection
        if cgpa >= 4.50:
            print("Class of Degree             : First Class Honors! 🎓")
        elif cgpa >= 3.50:
            print("Class of Degree             : Second Class Upper Division (2:1)")
        elif cgpa >= 2.40:
            print("Class of Degree             : Second Class Lower Division (2:2)")
        elif cgpa >= 1.50:
            print("Class of Degree             : Third Class Third Class")
        else:
            print("Class of Degree             : Pass")
    else:
        print("No valid academic records were entered.")
    print("=" * 50)

if __name__ == "__main__":
    main()
